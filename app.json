{
  "expo": {
    "name": "CyberLab Terminal",
    "slug": "cyberlab-terminal",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "cyberlabterminal",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050816"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cyberlabterminal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cyberlabterminal.app",
      "adaptiveIcon": {
        "backgroundColor": "#050816",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a5f3f27f-2e4a-4db6-827f-e5b6841e1947"
      }
    },
    "owner": "rushingtechnologies",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a5f3f27f-2e4a-4db6-827f-e5b6841e1947"
    }
  }
}
