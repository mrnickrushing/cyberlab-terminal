{
  "expo": {
    "name": "CyberLab Terminal",
    "slug": "cyberlab-terminal",
    "version": "2.0.0",
    "orientation": "default",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "scheme": "cyberlabterminal",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cyberlabterminal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow CyberLab Terminal to select screenshots from your photo library."
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CyberLab Terminal to select screenshots from your photo library."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050816"
        }
      ]
    ],
    "android": {
      "package": "com.cyberlabterminal.app",
      "adaptiveIcon": {
        "backgroundColor": "#050816",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a5f3f27f-2e4a-4db6-827f-e5b6841e1947"
      }
    },
    "owner": "rushingtechnologies",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a5f3f27f-2e4a-4db6-827f-e5b6841e1947",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    }
  }
}
