{
  "name": "cyberlab-terminal",
  "version": "2.0.0",
  "main": "index.ts",
  "dependencies": {
    "expo": "~56.0.16",
    "expo-clipboard": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image-picker": "~56.0.21",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.22",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate:ota": "node scripts/validate-ota-config.mjs",
    "ota:preview": "npx --yes eas-cli@21.0.1 update --channel preview --environment preview",
    "ota:production": "npx --yes eas-cli@21.0.1 update --channel production --environment production"
  },
  "private": true
